# Apply gtk theming
exec_always ~/.config/sway/scripts/import-gsettings

# Set inner/outer gaps
gaps inner 6
gaps outer 3

# Hide titlebar on windows:
default_border pixel 2

# Default Font
font pango:Hack Nerd Font 12

# Thin borders:
smart_borders on

# Set wallpaper:
exec ~/.azotebg
# Title format for windows
for_window [shell="xdg_shell"] title_format "%title (%app_id)"
for_window [shell="x_wayland"] title_format "%class - %title"

set $back #45475A
set $red #F38BA8
set $green #A6E3A1
set $yellow #F9E2AF
set $blue #89B4FA
set $magenta #F5C2E7
set $cyan #94E2D5
set $white #BAC2DE
set $bground #1E1E2E
set $fground #CDD6F4

# class                 border  bground text    indicator child_border
client.focused          $bground $bground $fground $blue   $blue
client.focused_inactive $bground $bground $fground $blue   $bground
client.unfocused        $bground $bground $fground $blue   $bground
client.urgent           $bground $bground $fground $blue   $red
client.placeholder      $bground $bground $fground $blue   $bground
client.background       $bground

#
# Status Bar:
#
# Read `man 5 sway-bar` for more information about this section.
bar {
    swaybar_command waybar
}
